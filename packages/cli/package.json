{
  "name": "supercode",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-model CLI coding agent — all the power of Claude Code, none of the vendor lock-in",
  "bin": {
    "supercode": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist/", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@supercode/core": "workspace:*",
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "vitest": "^1.5.0"
  },
  "keywords": ["ai", "coding-agent", "cli", "gemini", "openai", "claude", "code-assistant"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbellsolutions/supercode"
  }
}
