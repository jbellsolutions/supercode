{
  "name": "@supercode/dashboard",
  "version": "0.1.0",
  "type": "module",
  "description": "Local web dashboard for SuperCode",
  "bin": {
    "supercode-dashboard": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@supercode/core": "workspace:*",
    "express": "^4.19.0",
    "ws": "^8.17.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10"
  }
}
